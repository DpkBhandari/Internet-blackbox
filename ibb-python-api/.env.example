# ── Server ────────────────────────────────────────────────────────
APP_NAME=IBB-AI-Service
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_secret_key_min_32_chars
API_KEY=ibb_ai_internal_key_change_in_production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5000,http://localhost:5173

# ── Redis (cache + celery broker) ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CACHE_TTL_SECONDS=300

# ── MongoDB (optional - for persisting AI results) ────────────────
MONGO_URI=mongodb://localhost:27017/internet_black_box
MONGO_DB=internet_black_box

# ── Node.js Backend ───────────────────────────────────────────────
BACKEND_URL=http://localhost:5000
BACKEND_API_KEY=ibb_internal_service_key

# ── NLP Models ────────────────────────────────────────────────────
# Sentiment: distilbert-base-uncased-finetuned-sst-2-english (fast)
# Or: cardiffnlp/twitter-roberta-base-sentiment-latest (accurate)
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
NER_MODEL=en_core_web_sm
TOPIC_MODEL=facebook/bart-large-mnli
MISINFO_MODEL=rule_based
MODEL_CACHE_DIR=./cache/models
USE_GPU=false
BATCH_SIZE=32
MAX_TEXT_LENGTH=512
DEVICE=cpu

# ── News APIs ─────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_key_here
GUARDIAN_API_KEY=your_guardian_key_here

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=20

# ── Sentry (optional) ─────────────────────────────────────────────
SENTRY_DSN=
