{
  "name": "ibb-backend",
  "version": "2.0.0",
  "description": "Internet Black Box — Production Node.js/Express Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:cluster": "node dist/cluster.js",
    "seed": "ts-node src/utils/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3",
    "redis": "^4.6.12",
    "ioredis": "^5.3.2",
    "bull": "^4.12.2",
    "socket.io": "^4.6.2",
    "kafkajs": "^2.2.4",
    "multer": "^1.4.5-lts.1",
