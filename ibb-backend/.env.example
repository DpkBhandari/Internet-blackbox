# ── Server ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/internet_black_box
MONGO_POOL_SIZE=10

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_also_min_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=ibb:
CACHE_TTL_SECONDS=60

# ── Bull Queue (uses Redis) ──────────────────────────────────────────────
BULL_REDIS_URL=redis://localhost:6379

# ── Kafka (optional) ────────────────────────────────────────────────────
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ibb-backend
KAFKA_GROUP_ID=ibb-consumers

# ── AI/ML Service (Python FastAPI) ──────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=15000

# ── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
AUTH_LIMIT_MAX=20
UPLOAD_LIMIT_MAX=10

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ── File Uploads ─────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
UPLOAD_DIR=./uploads

# ── Email (Nodemailer) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@interndrive.in

# ── Prometheus Metrics ───────────────────────────────────────────────────
METRICS_PORT=9090
ENABLE_METRICS=true

# ── Web Scraper ──────────────────────────────────────────────────────────
SCRAPER_INTERVAL_MIN=15
NEWS_API_KEY=your_newsapi_key_here

# ── Security ─────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
COOKIE_SECRET=change_this_cookie_secret
