    "uuid": "^9.0.1",
    "compression": "^1.7.4",
    "prom-client": "^15.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "nodemailer": "^6.9.7",
    "csv-parser": "^3.0.0",
